{
  "name": "runordie-server",
  "private": true,
  "version": "1.0.0",
  "description": "RUN OR DIE — Backend: WebSocket-Relay + Konten-API für Online-Räume (bis 4 Spieler)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "errors": "node errors.js",
    "bugreports": "node bugreports.js",
    "netlog": "node netlog.js",
    "test:unit": "node --test test/db.unit.mjs test/seats.unit.mjs",
    "test:e2e": "node test/reconnect.e2e.mjs",
    "test:latency": "node test/latency.e2e.mjs",
    "test:online": "node test/online.e2e.mjs",
    "test:smoke": "node test/smoke.e2e.mjs",
    "test:spectatorcam": "node test/spectatorcam.e2e.mjs",
    "test:p2p": "node test/p2p.e2e.mjs",
    "test": "npm run test:unit && npm run test:smoke && npm run test:spectatorcam && npm run test:e2e && npm run test:online && npm run test:latency && npm run test:p2p"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1"
  }
}
